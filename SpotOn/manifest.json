{
  "manifest_version": 3,
  "name": "SpotOn",
  "version": "4.0.0",
  "description": "Enhance your Spotify Web Player experience with SpotOn. A complete UX/UI overhaul!",
  "author": "Kami",
  "homepage_url": "https://github.com/senpaihunters/spoton",
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "permissions": ["storage", "tabs", "scripting", "contextMenus", "commands"],
  "host_permissions": ["https://open.spotify.com/*"],
  "background": {
    "service_worker": "js/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://open.spotify.com/*"],
      "js": ["js/content.js", "js/utils/color-theming.js"],
      "css": ["css/spoton.css"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "commands": {
    "play-pause": {
      "description": "Play/Pause",
      "suggested_key": { "default": "MediaPlayPause" },
      "global": true
    },
    "previous": {
      "description": "Previous Track",
      "suggested_key": { "default": "MediaPrevTrack" },
      "global": true
    },
    "next": {
      "description": "Next Track",
      "suggested_key": {
        "default": "MediaNextTrack"
      },
      "global": true
    },
    "shuffle": { "description": "Toggle Shuffle" },
    "repeat": { "description": "Toggle Repeat" },
    "like": { "description": "Like Song" },
    "seek-forward": { "description": "Seek Forward" },
    "seek-backward": { "description": "Seek Backward" },
    "volume-up": { "description": "Volume Up" },
    "volume-down": { "description": "Volume Down" },
    "volume-mute": { "description": "Toggle Mute" }
  },
  "web_accessible_resources": [
    {
      "resources": ["css/*", "js/*", "update-notice.html"],
      "matches": ["https://open.spotify.com/*"]
    }
  ]
}
